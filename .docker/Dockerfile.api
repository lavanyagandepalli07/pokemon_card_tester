FROM node:20-alpine

WORKDIR /app

# Copy monorepo files
COPY package*.json tsconfig.base.json turbo.json ./
COPY apps/api ./apps/api
COPY packages/shared-types ./packages/shared-types

# Install dependencies
RUN npm ci

# Build shared types
RUN npm run --workspace=packages/shared-types build

# Build API
RUN npm run --workspace=apps/api build

EXPOSE 3001

CMD ["npm", "run", "--workspace=apps/api", "start"]
