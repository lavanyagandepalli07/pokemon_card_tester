# ============================================================================
# Pokemon Card Authentication Platform - Environment Variables Template
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git - it contains secrets!
# ============================================================================

# ============================================================================
# DATABASE (MongoDB)
# ============================================================================
MONGODB_URI=mongodb://localhost:27017/pokemon_card_auth
# Or for MongoDB Atlas (free tier):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pokemon_card_auth

# ============================================================================
# REDIS (Optional - for job queue)
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ============================================================================
# AUTHENTICATION (Supabase Auth)
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local fallback for development if you choose to run your own auth layer
# JWT_SECRET=your-super-secret-key-change-in-production
# JWT_EXPIRATION=7d
# JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
# JWT_REFRESH_EXPIRATION=30d
# BCRYPT_ROUNDS=10

# ============================================================================
# API
# ============================================================================
NODE_ENV=development
API_URL=http://localhost:3001
API_PORT=3001
API_LOG_LEVEL=debug

# ============================================================================
# WEB / FRONTEND
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=Pokemon Card Auth
NEXT_PUBLIC_APP_VERSION=0.1.0

# ============================================================================
# AI/ML SERVICE
# ============================================================================
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_PORT=8000
AI_MODEL_PATH=/models
AI_GPU_ENABLED=false
AI_LOG_LEVEL=info

# ============================================================================
# OCR CONFIGURATION
# ============================================================================
# Choose one: tesseract, google-vision, aws-textract
OCR_PROVIDER=tesseract
TESSERACT_PATH=/usr/bin/tesseract
GOOGLE_VISION_API_KEY=
GOOGLE_VISION_PROJECT_ID=

# ============================================================================
# FEATURES (Phase Flags)
# ============================================================================
FEATURE_AUTHENTICITY_DETECTION=false
FEATURE_CONDITION_ANALYSIS=false
FEATURE_GRADING_ESTIMATES=false
FEATURE_MOBILE_CAMERA=false
FEATURE_COLLECTIONS=false
FEATURE_PORTFOLIO=false

# ============================================================================
# RATE LIMITING & SECURITY
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ============================================================================
# FILE UPLOAD
# ============================================================================
MAX_UPLOAD_SIZE_MB=50
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
UPLOAD_TEMP_DIR=/tmp/uploads

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=debug
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ============================================================================
# EXTERNAL APIs (ALL FREE)
# ============================================================================
# Pokemon TCG API (pokemontcg.io) - Free tier: 20,000 requests/day
POKEMON_TCG_API_KEY=

# Optional: Resend (free tier email) or leave empty for testing
RESEND_API_KEY=

# ============================================================================
# TESTING
# ============================================================================
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=TestPassword123!
E2E_HEADLESS=true

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
# Enable debug logging and verbose output
DEBUG=*
VERBOSE_LOGGING=true

# Seed database with test data on startup
SEED_TEST_DATA=false
