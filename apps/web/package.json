{
  "name": "@pokemon-card-auth/web",
  "version": "0.1.0",
  "description": "Next.js frontend for Pokemon Card Authentication",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:prod": "next build",
    "start": "next start",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src",
